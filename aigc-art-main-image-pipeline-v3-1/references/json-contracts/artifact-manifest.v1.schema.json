{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "artifact-manifest.v1.schema.json",
  "title": "AIGC Art Artifact Manifest V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "skill_id",
    "skill_version",
    "project_id",
    "created_at",
    "artifacts"
  ],
  "properties": {
    "schema_version": {
      "const": "aigc-artifact-manifest.v1"
    },
    "skill_id": {
      "const": "aigc-art-main-image-pipeline-v3-1"
    },
    "skill_version": {
      "const": "3.1"
    },
    "project_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "role",
          "path",
          "artifact_type",
          "producer",
          "consumers",
          "required",
          "read_policy"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          },
          "role": {
            "enum": [
              "audit",
              "production_source",
              "deliverable",
              "validation_report"
            ]
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "artifact_type": {
            "enum": [
              "markdown",
              "markdown_table",
              "json",
              "docx",
              "directory",
              "report"
            ]
          },
          "producer": {
            "type": "string",
            "minLength": 1
          },
          "consumers": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": {
            "type": "boolean"
          },
          "read_policy": {
            "enum": [
              "audit_only",
              "production_source_only",
              "deliverable_only",
              "validation_only"
            ]
          }
        }
      }
    }
  }
}
