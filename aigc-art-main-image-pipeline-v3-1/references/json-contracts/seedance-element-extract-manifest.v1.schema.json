{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "seedance-element-extract-manifest.v1",
  "title": "Seedance Element Extract Manifest JSON v1",
  "type": "object",
  "required": ["schemaVersion", "assets"],
  "properties": {
    "schemaVersion": {
      "const": "seedance-element-extract-manifest.v1"
    },
    "manifestVersion": {
      "type": "string"
    },
    "generationScope": {
      "type": "string",
      "enum": ["main_image_only", "element_extract", "element_extract_with_main_images"]
    },
    "contentId": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "object",
      "properties": {
        "skillId": { "type": "string", "minLength": 1 },
        "skillVersion": { "type": "string" },
        "generatedAt": { "type": "string" },
        "sessionId": { "type": "string" }
      },
      "additionalProperties": true
    },
    "project": {
      "type": "object",
      "properties": {
        "title": { "type": "string" }
      },
      "additionalProperties": true
    },
    "summary": {
      "type": "object",
      "properties": {
        "totalItems": { "type": "integer", "minimum": 0 },
        "manualReviewItems": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": true
    },
    "assets": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/asset" }
    }
  },
  "additionalProperties": true,
  "$defs": {
    "asset": {
      "type": "object",
      "required": ["templateName", "templateType", "appearance"],
      "properties": {
        "assetId": {
          "type": "string"
        },
        "templateName": {
          "type": "string",
          "minLength": 1
        },
        "templateType": {
          "type": "string",
          "enum": ["ROLE", "SCENE", "PROP"]
        },
        "description": {
          "type": "string"
        },
        "coverImage": {
          "type": ["string", "null"]
        },
        "appearance": {
          "$ref": "#/$defs/appearance"
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "appearance": {
      "type": "object",
      "required": ["appearances"],
      "properties": {
        "description": {
          "type": "string"
        },
        "appearances": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/appearanceState" }
        }
      },
      "additionalProperties": true
    },
    "appearanceState": {
      "type": "object",
      "required": ["name", "imagePrompt"],
      "properties": {
        "stateId": {
          "type": "string"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "episodes": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 1
          }
        },
        "imageRatio": {
          "type": "string"
        },
        "imagePrompt": {
          "type": "string",
          "minLength": 1
        },
        "negativePrompt": {
          "type": "string"
        },
        "priority": {
          "type": "string",
          "enum": ["S", "A", "B", "C"]
        },
        "status": {
          "type": "string"
        },
        "generation": {
          "type": "object",
          "properties": {
            "method": {
              "type": "string",
              "enum": ["text_to_image", "image_to_image", "image_text_edit"]
            },
            "referenceTaskId": { "type": "string" },
            "referenceAssetId": { "type": "string" },
            "referenceStateId": { "type": "string" },
            "referenceAppearanceName": { "type": "string" }
          },
          "additionalProperties": true
        },
        "reviewFocus": {
          "type": ["string", "array"]
        }
      },
      "additionalProperties": true
    }
  }
}
